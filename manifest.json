{
  "manifest_version": 3,
  "name": "LinkedIn Applicant Filter",
  "version": "0.4.0",
  "description": "Auto-fetches per-job applicant counts on LinkedIn search and lets you bucket-filter low-competition jobs.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LinkedIn Applicant Filter (\u70b9\u51fb\u5207\u6362\u7b5b\u9009\u6761)"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "parser.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "main_world.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon/16.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  }
}
